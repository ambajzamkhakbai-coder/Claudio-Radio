# AI 音乐电台服务配置
PORT=8080

# Gemini API 配置
# 请在此处填写你的 Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Fish Audio TTS 配置
# 请在此处填写你的 Fish Audio API Key
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here
# 知性女声的 Voice ID，可以填写 Fish Audio 的官方或者你克隆的角色 ID
FISH_AUDIO_VOICE_ID=7f113a778e884144b60e33ef72d763ed

# OpenWeather API 配置（获取天气信息，可选）
OPENWEATHER_API_KEY=your_openweather_api_key_here
WEATHER_CITY=Beijing

# 网易云音乐 API 地址
# 默认使用本地启动的 NeteaseCloudMusicApi 端口 3000
NETEASE_API_URL=http://localhost:3000
